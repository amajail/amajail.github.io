---
import { t } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  currentPage?: string;
}

const { lang, currentPage } = Astro.props;
const otherLang = lang === 'en' ? 'es' : 'en';

const navLinks = [
  { page: 'about', label: t(lang, 'nav.about'), href: `/${lang}/about` },
  { page: 'experience', label: t(lang, 'nav.experience'), href: `/${lang}/experience` },
  { page: 'projects', label: t(lang, 'nav.projects'), href: `/${lang}/projects` },
  { page: 'certifications', label: t(lang, 'nav.certifications'), href: `/${lang}/certifications` },
  { page: 'contact', label: t(lang, 'nav.contact'), href: `/${lang}/contact` },
];

// Build the language switcher URL by replacing the lang prefix
const currentPath = Astro.url.pathname;
const langSwitcherHref = currentPath.replace(`/${lang}`, `/${otherLang}`);
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/90 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 md:px-6">
    <!-- Logo / site name -->
    <a href={`/${lang}/`} class="font-mono text-sm font-semibold text-accent hover:opacity-80 transition-opacity">
      <span class="text-muted">~/</span>amajail
    </a>

    <!-- Mobile menu toggle -->
    <button
      id="nav-toggle"
      class="flex md:hidden flex-col gap-1.5 p-2 text-text-primary hover:text-accent transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-5 bg-current transition-transform" id="bar1"></span>
      <span class="block h-0.5 w-5 bg-current transition-opacity" id="bar2"></span>
      <span class="block h-0.5 w-5 bg-current transition-transform" id="bar3"></span>
    </button>

    <!-- Nav links -->
    <ul
      id="nav-menu"
      class="hidden md:flex items-center gap-6 text-sm font-medium"
    >
      {navLinks.map(({ page, label, href }) => (
        <li>
          <a
            href={href}
            class={`transition-colors hover:text-accent ${
              currentPage === page
                ? 'text-accent border-b border-accent pb-0.5'
                : 'text-muted'
            }`}
          >
            {label}
          </a>
        </li>
      ))}

      <!-- Language switcher -->
      <li class="ml-2 flex items-center gap-1 font-mono text-xs">
        <span class={lang === 'en' ? 'text-accent' : 'text-muted'}>EN</span>
        <span class="text-border">|</span>
        <a
          href={langSwitcherHref}
          class={lang === 'es' ? 'text-accent' : 'text-muted hover:text-text-primary transition-colors'}
        >
          ES
        </a>
      </li>
    </ul>
  </nav>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface px-4 pb-4">
    <ul class="flex flex-col gap-1 pt-3 text-sm">
      {navLinks.map(({ page, label, href }) => (
        <li>
          <a
            href={href}
            class={`block rounded px-2 py-2 transition-colors hover:text-accent ${
              currentPage === page ? 'text-accent' : 'text-muted'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="mt-2 flex items-center gap-2 px-2 font-mono text-xs">
        <span class={lang === 'en' ? 'text-accent' : 'text-muted'}>EN</span>
        <span class="text-border">|</span>
        <a
          href={langSwitcherHref}
          class={lang === 'es' ? 'text-accent' : 'text-muted hover:text-text-primary transition-colors'}
        >
          ES
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    bar1?.classList.toggle('translate-y-2');
    bar1?.classList.toggle('rotate-45');
    bar2?.classList.toggle('opacity-0');
    bar3?.classList.toggle('-translate-y-2');
    bar3?.classList.toggle('-rotate-45');
  });
</script>
