---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const lang = Astro.params.lang as Lang;

interface Cert {
  name: string;
  code: string;
  issued: string;
  renew: string | null;
  credentialId: string;
  verifyUrl: string;
  noExpiry?: boolean;
}

const SHARE = 'https://learn.microsoft.com/api/credentials/share/en-us/AdrianGustavoMajail-2382';

const certs: Record<Lang, Cert[]> = {
  en: [
    { name: 'Azure Solutions Architect Expert', code: 'AZ-305', issued: 'Dec 2023', renew: 'Dec 2026', credentialId: '75ADDB90F094CD39', verifyUrl: `${SHARE}/75ADDB90F094CD39?sharingId=89501934FF3B930B` },
    { name: 'Azure Developer Associate',        code: 'AZ-204', issued: 'Jun 2023', renew: 'Jun 2026', credentialId: 'EDD7BD443196A72F', verifyUrl: `${SHARE}/EDD7BD443196A72F?sharingId=89501934FF3B930B` },
    { name: 'Azure Administrator Associate',    code: 'AZ-104', issued: 'Jul 2023', renew: 'Jul 2026', credentialId: 'BCEA09FDB40FA35F', verifyUrl: `${SHARE}/BCEA09FDB40FA35F?sharingId=89501934FF3B930B` },
    { name: 'Azure AI Fundamentals',            code: 'AI-900', issued: 'Jan 2025', renew: null,       credentialId: '65ACE18EEF332F7C', verifyUrl: `${SHARE}/65ACE18EEF332F7C?sharingId=89501934FF3B930B`, noExpiry: true },
  ],
  es: [
    { name: 'Azure Solutions Architect Expert', code: 'AZ-305', issued: 'Dic 2023', renew: 'Dic 2026', credentialId: '75ADDB90F094CD39', verifyUrl: `${SHARE}/75ADDB90F094CD39?sharingId=89501934FF3B930B` },
    { name: 'Azure Developer Associate',        code: 'AZ-204', issued: 'Jun 2023', renew: 'Jun 2026', credentialId: 'EDD7BD443196A72F', verifyUrl: `${SHARE}/EDD7BD443196A72F?sharingId=89501934FF3B930B` },
    { name: 'Azure Administrator Associate',    code: 'AZ-104', issued: 'Jul 2023', renew: 'Jul 2026', credentialId: 'BCEA09FDB40FA35F', verifyUrl: `${SHARE}/BCEA09FDB40FA35F?sharingId=89501934FF3B930B` },
    { name: 'Azure AI Fundamentals',            code: 'AI-900', issued: 'Ene 2025', renew: null,       credentialId: '65ACE18EEF332F7C', verifyUrl: `${SHARE}/65ACE18EEF332F7C?sharingId=89501934FF3B930B`, noExpiry: true },
  ],
};

const inProgress = {
  en: [
    { code: 'AI-200', name: 'Azure AI Cloud Developer Associate',   target: 'mid 2026' },
    { code: 'AI-103', name: 'Azure AI App and Agent Developer Associate', target: '2026' },
  ],
  es: [
    { code: 'AI-200', name: 'Azure AI Cloud Developer Associate',   target: 'mediados 2026' },
    { code: 'AI-103', name: 'Azure AI App and Agent Developer Associate', target: '2026' },
  ],
};

const learnStats = [
  { value: '87', label: { en: 'Badges earned',  es: 'Badges obtenidos' } },
  { value: '18', label: { en: 'Trophies',        es: 'Trofeos' } },
  { value: '10', label: { en: 'Level',           es: 'Nivel' } },
];

const pageTitle    = { en: 'Certifications',  es: 'Certificaciones' };
const issuedLabel  = { en: 'Issued',          es: 'Obtenida' };
const targetLabel  = { en: 'Target',          es: 'Objetivo' };
const noExpiryLabel = { en: 'No expiry',      es: 'Sin vencimiento' };
const msLearnLabel = { en: 'Microsoft Learn Stats', es: 'Stats en Microsoft Learn' };
const inProgressTitle = { en: 'In Progress',  es: 'En Progreso' };
---

<BaseLayout
  lang={lang}
  title={`${pageTitle[lang]} — Adrian Majail`}
  description="Microsoft Azure certifications: AZ-305, AZ-204, AZ-104, AI-900. 87 MS Learn badges."
  currentPage="certifications"
>
  <div class="mx-auto max-w-5xl px-4 py-16 md:px-6 md:py-20">

    <header class="mb-12">
      <p class="eyebrow mb-1">{lang === 'en' ? 'Microsoft Azure' : 'Microsoft Azure'}</p>
      <span class="accent-line"></span>
      <h1 class="text-3xl font-extrabold tracking-tight text-text-primary sm:text-4xl">{pageTitle[lang]}</h1>
    </header>

    <!-- Active certs grid -->
    <section class="mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-5">{t(lang, 'certifications.active')}</p>
      <div class="grid gap-4 sm:grid-cols-2">
        {certs[lang].map((cert) => (
          <div class="rounded-xl border border-border bg-surface shadow-card p-5 hover:shadow-card-hover hover:border-border-2 transition-all">
            <div class="mb-3 flex items-start justify-between gap-2">
              <span class="inline-block rounded-lg border border-accent/30 bg-blue-50 px-3 py-1 font-mono text-sm font-bold text-accent">
                {cert.code}
              </span>
              {cert.noExpiry ? (
                <span class="rounded-full border border-accent-2/30 bg-cyan-50 px-2.5 py-0.5 text-xs font-semibold text-accent-2">
                  {noExpiryLabel[lang]}
                </span>
              ) : (
                <span class="rounded-full border border-accent/20 bg-blue-50 px-2.5 py-0.5 text-xs font-semibold text-accent">
                  {t(lang, 'certifications.active')}
                </span>
              )}
            </div>

            <h2 class="mb-3 text-sm font-bold text-text-primary leading-snug">{cert.name}</h2>

            <dl class="space-y-1 text-xs text-muted mb-4">
              <div class="flex items-center gap-2">
                <dt class="text-border-2">{issuedLabel[lang]}:</dt>
                <dd class="font-medium">{cert.issued}</dd>
              </div>
              {cert.renew && (
                <div class="flex items-center gap-2">
                  <dt class="text-border-2">{t(lang, 'certifications.renew')}:</dt>
                  <dd class="font-medium text-accent-2">{cert.renew}</dd>
                </div>
              )}
              <div class="flex items-center gap-2">
                <dt class="text-border-2">ID:</dt>
                <dd class="font-mono select-all text-muted/70">{cert.credentialId}</dd>
              </div>
            </dl>

            <a
              href={cert.verifyUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent hover:underline"
            >
              {lang === 'en' ? 'Verify credential' : 'Verificar credencial'}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- MS Learn Stats -->
    <section class="mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-5">{msLearnLabel[lang]}</p>
      <div class="rounded-xl border border-border bg-surface shadow-card p-6">
        <div class="grid grid-cols-3 gap-6 text-center mb-5">
          {learnStats.map(({ value, label }) => (
            <div>
              <p class="text-3xl font-extrabold text-text-primary tracking-tight">{value}</p>
              <p class="mt-1 text-xs font-medium text-muted">{label[lang]}</p>
            </div>
          ))}
        </div>
        <div class="border-t border-border pt-4 text-center">
          <a
            href="https://learn.microsoft.com/en-us/users/adriangustavomajail-2382/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent hover:underline"
          >
            {lang === 'en' ? 'View MS Learn profile' : 'Ver perfil en MS Learn'}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- In Progress -->
    <section>
      <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-5">{t(lang, 'certifications.in_progress')}</p>
      <h2 class="text-xl font-bold text-text-primary mb-5">{inProgressTitle[lang]}</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {inProgress[lang].map((cert) => (
          <div class="rounded-xl border border-dashed border-border-2 bg-surface-2 p-5">
            <div class="mb-3 flex items-start justify-between gap-2">
              <span class="inline-block rounded-lg border border-border-2 px-3 py-1 font-mono text-sm font-bold text-muted">
                {cert.code}
              </span>
              <span class="rounded-full border border-border-2 px-2.5 py-0.5 text-xs font-medium text-muted">
                {t(lang, 'certifications.in_progress')}
              </span>
            </div>
            <h3 class="mb-2 text-sm font-semibold text-muted leading-snug">{cert.name}</h3>
            <p class="text-xs text-muted">
              <span class="font-medium">{targetLabel[lang]}:</span> {cert.target}
            </p>
          </div>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
