---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const lang = Astro.params.lang as Lang;

interface Project {
  title: string;
  client: string;
  period: string;
  description: string;
  highlights: string[];
  stack: string[];
  featured?: boolean;
  badgeLabel?: string;
}

const projects: Record<Lang, Project[]> = {
  en: [
    {
      title: 'Agent Management Platform',
      client: 'Big Four (confidential) · CloudX',
      period: '2024–2025',
      featured: true,
      badgeLabel: 'Featured',
      description:
        'An enterprise platform for managing AI agents that perform Retrieval-Augmented Generation (RAG), consuming MCP tools and OpenAPI plugins. Built to scale across multiple business units with full enterprise integration.',
      highlights: [
        'RAG pipeline orchestration with MCP and OpenAPI plugin consumption',
        'Real-time agent status via SignalR',
        'Multi-team delivery across 5 teams in 4 countries',
        'Secure identity management with Microsoft Entra',
        'Event-driven architecture with Azure Service Bus',
      ],
      stack: ['React', 'PostgreSQL', 'Azure Cosmos DB', 'AKS', 'Azure Functions', 'Service Bus', 'App Configuration', 'SignalR', 'Terraform', 'GitHub Actions', 'Microsoft Entra'],
    },
    {
      title: 'Enterprise Tax Platform',
      client: 'Big Four (confidential) · Cognizant Softvision',
      period: '2022–2024',
      description:
        'A large-scale tax management platform for a global firm. Microservices architecture with full Azure integration, Power BI reporting, and security hardening via SonarQube.',
      highlights: [
        'SAFe PI planning across multicultural teams',
        'Redis caching for high-performance data access',
        'SonarQube security and code quality enforcement',
        'Power BI integration for executive reporting',
      ],
      stack: ['.NET', 'REST APIs', 'Azure Functions', 'Service Bus', 'Redis', 'SQL', 'Power BI', 'SonarQube'],
    },
    {
      title: 'University Enterprise Platform',
      client: 'UADE',
      period: '2009–2020',
      description:
        'Long-running platform serving 20,000+ users. Evolved from a .NET monolith to an Azure-hosted, scalable system with CI/CD automation, payment integration, and high-concurrency handling.',
      highlights: [
        'Scaled to handle large concurrent user loads on Azure',
        'Automated CI/CD with Jenkins pipelines',
        'Oracle PL/SQL: procedures, packages, functions',
        'Payment gateway integration',
      ],
      stack: ['.NET 4.8', 'Oracle (PL/SQL)', 'Azure', 'Jenkins', 'REST APIs'],
    },
  ],
  es: [
    {
      title: 'Agent Management Platform',
      client: 'Big Four (confidencial) · CloudX',
      period: '2024–2025',
      featured: true,
      badgeLabel: 'Destacado',
      description:
        'Plataforma enterprise para gestión de agentes de IA que realizan Retrieval-Augmented Generation (RAG), consumiendo herramientas MCP y plugins OpenAPI. Construida para escalar en múltiples unidades de negocio con integración enterprise completa.',
      highlights: [
        'Orquestación de pipelines RAG con MCP y plugins OpenAPI',
        'Estado de agentes en tiempo real vía SignalR',
        'Entrega multi-equipo en 5 equipos de 4 países',
        'Gestión de identidad segura con Microsoft Entra',
        'Arquitectura event-driven con Azure Service Bus',
      ],
      stack: ['React', 'PostgreSQL', 'Azure Cosmos DB', 'AKS', 'Azure Functions', 'Service Bus', 'App Configuration', 'SignalR', 'Terraform', 'GitHub Actions', 'Microsoft Entra'],
    },
    {
      title: 'Plataforma de Impuestos Enterprise',
      client: 'Big Four (confidencial) · Cognizant Softvision',
      period: '2022–2024',
      description:
        'Plataforma de gestión tributaria a gran escala para una empresa global. Arquitectura de microservicios con integración completa en Azure, reportes Power BI y hardening de seguridad con SonarQube.',
      highlights: [
        'SAFe PI planning en equipos multiculturales',
        'Redis para acceso a datos de alta performance',
        'Calidad de código y seguridad con SonarQube',
        'Integración con Power BI para reportes ejecutivos',
      ],
      stack: ['.NET', 'REST APIs', 'Azure Functions', 'Service Bus', 'Redis', 'SQL', 'Power BI', 'SonarQube'],
    },
    {
      title: 'Plataforma Enterprise Universitaria',
      client: 'UADE',
      period: '2009–2020',
      description:
        'Plataforma de larga duración para más de 20.000 usuarios. Evolucionó de un monolito .NET a un sistema escalable en Azure con CI/CD automatizado, integración de pagos y manejo de alta concurrencia.',
      highlights: [
        'Escalado para alta concurrencia en Azure',
        'CI/CD automatizado con Jenkins',
        'Oracle PL/SQL: procedimientos, paquetes y funciones',
        'Integración con pasarela de pagos',
      ],
      stack: ['.NET 4.8', 'Oracle (PL/SQL)', 'Azure', 'Jenkins', 'REST APIs'],
    },
  ],
};

const pageTitle = { en: 'Projects', es: 'Proyectos' };
const clientLabel = { en: 'Client', es: 'Cliente' };
const highlightsLabel = { en: 'Highlights', es: 'Destacados' };
---

<BaseLayout
  lang={lang}
  title={`${pageTitle[lang]} — Adrian Majail`}
  description="Featured projects: AI agent platforms, enterprise tax systems, and long-running university infrastructure."
  currentPage="projects"
>
  <div class="mx-auto max-w-5xl px-4 py-16 md:px-6 md:py-20">

    <!-- Page heading -->
    <header class="mb-12">
      <p class="mb-3 font-mono text-xs text-accent uppercase tracking-widest">
        <span class="text-muted">{'>'}</span> {lang === 'en' ? 'projects' : 'proyectos'}
      </p>
      <h1 class="text-3xl font-bold text-text-primary sm:text-4xl">{pageTitle[lang]}</h1>
    </header>

    <!-- Project cards -->
    <div class="space-y-8">
      {projects[lang].map((project) => (
        <article
          class={`rounded-lg border bg-surface p-6 md:p-8 transition-colors ${
            project.featured
              ? 'border-accent/40 shadow-lg shadow-accent/5'
              : 'border-border hover:border-border/60'
          }`}
        >
          <!-- Card header -->
          <div class="mb-4 flex flex-wrap items-start justify-between gap-3">
            <div>
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <h2 class="text-xl font-bold text-text-primary">{project.title}</h2>
                {project.featured && (
                  <span class="rounded-full border border-accent/50 bg-accent/10 px-2.5 py-0.5 font-mono text-xs font-semibold text-accent">
                    {project.badgeLabel}
                  </span>
                )}
              </div>
              <p class="font-mono text-xs text-muted">
                <span class="text-accent-2">{clientLabel[lang]}:</span> {project.client} · {project.period}
              </p>
            </div>
          </div>

          <!-- Description -->
          <p class="mb-6 text-sm text-muted leading-relaxed">{project.description}</p>

          <!-- Highlights -->
          <div class="mb-6">
            <p class="mb-2 font-mono text-xs text-muted uppercase tracking-widest">{highlightsLabel[lang]}</p>
            <ul class="space-y-1.5">
              {project.highlights.map((h) => (
                <li class="flex items-start gap-2 text-sm text-muted">
                  <span class="text-accent shrink-0 mt-0.5">▸</span>
                  {h}
                </li>
              ))}
            </ul>
          </div>

          <!-- Stack -->
          <div>
            <p class="mb-2 font-mono text-xs text-muted uppercase tracking-widest">Stack</p>
            <div class="flex flex-wrap gap-1.5">
              {project.stack.map((tag) => (
                <span class={`rounded border px-2 py-0.5 font-mono text-xs ${
                  project.featured ? 'border-accent/30 text-accent/80' : 'border-border text-muted'
                }`}>
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Footer note -->
    <p class="mt-10 font-mono text-xs text-muted text-center">
      {lang === 'en'
        ? '// More projects and open source work coming soon'
        : '// Más proyectos y trabajo open source próximamente'}
    </p>

  </div>
</BaseLayout>
