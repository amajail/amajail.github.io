---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, heroContent } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const lang = Astro.params.lang as Lang;
const hero = heroContent[lang];

const certs = ['AZ-305', 'AZ-204', 'AZ-104', 'AI-900'];

const skills = ['.NET / C#', 'Azure', 'AI Agents', 'RAG', 'MCP', 'Team Lead', 'Terraform', 'DevOps'];

const stats = [
  { value: '20+', label: lang === 'en' ? 'Years exp.' : 'Años exp.' },
  { value: '3',   label: lang === 'en' ? 'Big Four' : 'Big Four' },
  { value: '10+', label: lang === 'en' ? 'Countries' : 'Países' },
  { value: '4',   label: lang === 'en' ? 'Azure certs' : 'Cert. Azure' },
];

const socialLinks = [
  { label: 'GitHub',   href: 'https://github.com/amajail',        external: true },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/amajail',   external: true },
  { label: 'Email',    href: 'mailto:adrian.majail@live.com.ar',  external: false },
];
---

<BaseLayout
  lang={lang}
  title="Adrian Majail — .NET Tech Lead & AI Builder"
  description={hero.description}
  currentPage="home"
>

  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-4 py-16 md:py-24 md:px-6">
    <div class="grid gap-12 lg:grid-cols-[1fr_360px] lg:gap-16 items-start">

      <!-- Left: content -->
      <div>
        <!-- Availability pill -->
        <div class="inline-flex items-center gap-2 rounded-full border border-border bg-surface-2 px-3 py-1.5 text-xs font-semibold text-muted mb-6">
          <span class="h-1.5 w-1.5 rounded-full bg-accent-2 shrink-0"></span>
          {t(lang, 'contact.availability')}
        </div>

        <h1 class="text-4xl font-extrabold tracking-tight text-text-primary sm:text-5xl leading-[1.08] mb-4">
          {hero.headline}
        </h1>

        <span class="block w-10 h-0.5 bg-accent mb-5"></span>

        <p class="text-base font-semibold text-accent-2 mb-4 leading-relaxed">
          {hero.subheadline}
        </p>

        <p class="text-base text-muted leading-relaxed mb-8 max-w-xl">
          {hero.description}
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 mb-8">
          <a
            href={`/${lang}/projects`}
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-white shadow-btn transition-all hover:bg-accent-h hover:shadow-btn-hover"
          >
            {t(lang, 'hero.cta_primary')}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          </a>
          <a
            href={`/${lang}/contact`}
            class="inline-flex items-center gap-2 rounded-lg border border-border-2 px-5 py-3 text-sm font-semibold text-text-primary transition-all hover:border-accent hover:text-accent"
          >
            {t(lang, 'hero.cta_secondary')}
          </a>
        </div>

        <!-- Socials -->
        <div class="flex items-center gap-5">
          {socialLinks.map(({ label, href, external }) => (
            <a
              href={href}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
              class="text-sm font-medium text-muted hover:text-accent transition-colors border-b border-transparent hover:border-accent pb-0.5"
            >
              {label}
            </a>
          ))}
        </div>
      </div>

      <!-- Right: profile card -->
      <div class="flex flex-col gap-4 lg:pt-2">
        <!-- Profile -->
        <div class="rounded-xl border border-border bg-surface shadow-card overflow-hidden">
          <div class="h-1 w-full bg-gradient-to-r from-accent to-accent-2"></div>
          <div class="p-6">
            <div class="flex items-center gap-3 mb-5">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-accent to-accent-2 text-lg font-extrabold text-white">
                AM
              </div>
              <div>
                <p class="text-sm font-bold text-text-primary">Adrian Majail</p>
                <p class="text-xs text-muted mt-0.5">Dev Team Lead @ CloudX</p>
              </div>
            </div>

            <!-- Mini stats -->
            <div class="grid grid-cols-2 gap-2 mb-5">
              {stats.map(({ value, label }) => (
                <div class="rounded-lg bg-surface-2 px-3 py-2.5 text-center">
                  <p class="text-xl font-extrabold text-text-primary tracking-tight">{value}</p>
                  <p class="text-xs text-muted mt-0.5">{label}</p>
                </div>
              ))}
            </div>

            <!-- Skill tags -->
            <div class="flex flex-wrap gap-1.5">
              {skills.map((s) => (
                <span class="rounded-md border border-border bg-surface-2 px-2 py-0.5 text-xs font-medium text-muted">
                  {s}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- Azure certs card -->
        <div class="rounded-xl border border-border bg-surface shadow-card p-5">
          <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">
            Azure {lang === 'en' ? 'Certifications' : 'Certificaciones'}
          </p>
          <div class="space-y-2">
            {certs.map((code) => (
              <div class="flex items-center justify-between rounded-lg bg-surface-2 px-3 py-2">
                <span class="text-sm font-bold text-accent">{code}</span>
                <span class="rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-accent-2">
                  {t(lang, 'certifications.active')}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Stats strip -->
  <section class="border-y border-border bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-10 md:px-6">
      <dl class="grid grid-cols-2 gap-8 sm:grid-cols-4 text-center">
        {[
          { value: '20+', label: lang === 'en' ? 'Years of experience' : 'Años de experiencia' },
          { value: '5+',  label: lang === 'en' ? 'Companies'           : 'Empresas' },
          { value: '10+', label: lang === 'en' ? 'Countries (teams)'   : 'Países (equipos)' },
          { value: '3',   label: lang === 'en' ? 'Big Four projects'   : 'Proyectos Big Four' },
        ].map(({ value, label }) => (
          <div>
            <dt class="text-3xl font-extrabold text-text-primary tracking-tight">{value}</dt>
            <dd class="mt-1 text-xs font-medium text-muted">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- About teaser -->
  <section class="mx-auto max-w-6xl px-4 py-16 md:px-6 md:py-20">
    <div class="grid gap-12 md:grid-cols-2 items-start">
      <div>
        <p class="eyebrow mb-1">{lang === 'en' ? 'About' : 'Sobre mí'}</p>
        <span class="accent-line"></span>
        <h2 class="text-2xl font-extrabold tracking-tight text-text-primary mb-4">
          {lang === 'en' ? 'I lead by doing.' : 'Lidero haciendo.'}
        </h2>
        <p class="text-muted leading-relaxed mb-6">
          {lang === 'en'
            ? "I'm a .NET Tech Lead and AI Builder with 20 years across the full stack — from on-prem enterprise systems to cloud-native microservices and AI agent platforms. My focus is on shipping things that matter: well-architected, production-grade systems."
            : 'Soy un .NET Tech Lead y AI Builder con 20 años en todo el stack — desde sistemas enterprise on-prem hasta microservicios cloud-native y plataformas de agentes de IA. Mi foco es en entregar cosas que importan: sistemas bien arquitectados y production-grade.'}
        </p>
        <a href={`/${lang}/about`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent hover:underline">
          {lang === 'en' ? 'Read more' : 'Leer más'}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </a>
      </div>

      <div>
        <p class="eyebrow mb-1">{lang === 'en' ? 'Core stack' : 'Stack principal'}</p>
        <span class="accent-line"></span>
        <div class="flex flex-wrap gap-2">
          {[
            '.NET / C#', 'Azure', 'React', 'GraphQL', 'Terraform', 'Docker',
            'RAG', 'MCP', 'Azure OpenAI', 'PostgreSQL', 'Cosmos DB',
            'GitHub Actions', 'Azure DevOps', 'SAFe',
          ].map((tag) => (
            <span class="rounded-md border border-border bg-surface px-2.5 py-1 text-xs font-medium text-muted hover:border-accent hover:text-accent transition-colors cursor-default shadow-sm">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
