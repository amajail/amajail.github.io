---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerminalBlock from '../../components/TerminalBlock.astro';
import { t, heroContent } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const lang = Astro.params.lang as Lang;
const hero = heroContent[lang];

const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/amajail',
    icon: `<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/amajail',
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    label: 'Email',
    href: 'mailto:adrian.majail@live.com.ar',
    icon: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
    stroke: true,
  },
];
---

<BaseLayout
  lang={lang}
  title="Adrian Majail — .NET Tech Lead & AI Builder"
  description={hero.description}
  currentPage="home"
>
  <!-- Hero section -->
  <section class="relative mx-auto max-w-6xl px-4 py-16 md:py-24 md:px-6">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-center">

      <!-- Left: text content -->
      <div class="flex flex-col gap-6 order-2 lg:order-1">
        <!-- Label -->
        <p class="font-mono text-xs text-accent uppercase tracking-widest">
          <span class="text-muted">{'>'}</span> {lang === 'en' ? 'Hello, world' : 'Hola, mundo'}
        </p>

        <!-- Headline -->
        <h1 class="text-3xl font-bold leading-tight text-text-primary sm:text-4xl md:text-5xl">
          {hero.headline}
        </h1>

        <!-- Subheadline -->
        <p class="font-mono text-base text-accent-2 leading-relaxed">
          {hero.subheadline}
        </p>

        <!-- Description -->
        <p class="text-muted leading-relaxed max-w-xl">
          {hero.description}
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-3 pt-2">
          <a
            href={`/${lang}/projects`}
            class="inline-flex items-center gap-2 rounded border border-accent bg-accent px-5 py-2.5 font-mono text-sm font-semibold text-bg transition-all hover:bg-accent/90 hover:shadow-lg hover:shadow-accent/20"
          >
            {t(lang, 'hero.cta_primary')}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14m-7-7 7 7-7 7"/>
            </svg>
          </a>
          <a
            href={`/${lang}/contact`}
            class="inline-flex items-center gap-2 rounded border border-border px-5 py-2.5 font-mono text-sm font-semibold text-text-primary transition-all hover:border-accent hover:text-accent"
          >
            {t(lang, 'hero.cta_secondary')}
          </a>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-4 pt-2">
          {socialLinks.map(({ label, href, icon, stroke }) => (
            <a
              href={href}
              target={href.startsWith('mailto') ? undefined : '_blank'}
              rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              aria-label={label}
              class="text-muted hover:text-accent transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill={stroke ? 'none' : 'currentColor'}
                stroke={stroke ? 'currentColor' : undefined}
                stroke-width={stroke ? '2' : undefined}
                stroke-linecap={stroke ? 'round' : undefined}
                stroke-linejoin={stroke ? 'round' : undefined}
                set:html={icon}
              />
            </a>
          ))}
        </div>
      </div>

      <!-- Right: terminal block -->
      <div class="order-1 lg:order-2">
        <TerminalBlock lines={hero.terminal} />
      </div>
    </div>

    <!-- Decorative grid background -->
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(to_right,#30363d_1px,transparent_1px),linear-gradient(to_bottom,#30363d_1px,transparent_1px)] bg-[size:48px_48px] opacity-20 [mask-image:radial-gradient(ellipse_at_center,black_40%,transparent_80%)]"
    ></div>
  </section>

  <!-- Stats strip -->
  <section class="border-y border-border bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-8 md:px-6">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {[
          { value: '20+', label: lang === 'en' ? 'Years experience' : 'Años de experiencia' },
          { value: '5+', label: lang === 'en' ? 'Companies' : 'Empresas' },
          { value: '10+', label: lang === 'en' ? 'Countries (teams)' : 'Países (equipos)' },
          { value: '3', label: lang === 'en' ? 'Big Four projects' : 'Proyectos Big Four' },
        ].map(({ value, label }) => (
          <div>
            <dt class="font-mono text-2xl font-bold text-accent">{value}</dt>
            <dd class="mt-1 text-xs text-muted">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Quick intro / About teaser -->
  <section class="mx-auto max-w-6xl px-4 py-16 md:px-6 md:py-20">
    <div class="grid gap-10 md:grid-cols-2 items-start">
      <div>
        <p class="font-mono text-xs text-accent uppercase tracking-widest mb-4">
          <span class="text-muted">{'>'}</span> {lang === 'en' ? 'about' : 'sobre_mí'}
        </p>
        <h2 class="text-2xl font-bold text-text-primary mb-4">
          {lang === 'en'
            ? 'I lead by doing.'
            : 'Lidero haciendo.'}
        </h2>
        <p class="text-muted leading-relaxed mb-6">
          {lang === 'en'
            ? "I'm a .NET Tech Lead and AI Builder with 20 years across the full stack — from on-prem enterprise systems to cloud-native microservices and AI agent platforms. My focus is on shipping things that matter: well-architected, production-grade systems."
            : 'Soy un .NET Tech Lead y AI Builder con 20 años en todo el stack — desde sistemas enterprise on-prem hasta microservicios cloud-native y plataformas de agentes de IA. Mi foco es en entregar cosas que importan: sistemas bien arquitectados y production-grade.'}
        </p>
        <a
          href={`/${lang}/about`}
          class="inline-flex items-center gap-1.5 font-mono text-sm text-accent hover:underline"
        >
          {lang === 'en' ? 'Read more' : 'Leer más'}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14m-7-7 7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Skill tags -->
      <div>
        <p class="font-mono text-xs text-muted mb-4">
          {lang === 'en' ? '// core stack' : '// stack principal'}
        </p>
        <div class="flex flex-wrap gap-2">
          {[
            '.NET / C#', 'Azure', 'React', 'GraphQL',
            'Terraform', 'Docker', 'RAG', 'MCP',
            'Azure OpenAI', 'PostgreSQL', 'Cosmos DB',
            'GitHub Actions', 'Azure DevOps', 'SAFe',
          ].map((tag) => (
            <span class="rounded border border-border bg-surface px-2.5 py-1 font-mono text-xs text-muted hover:border-accent hover:text-accent transition-colors cursor-default">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
