---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const lang = Astro.params.lang as Lang;

interface TimelineEntry {
  title: string;
  company: string;
  companyUrl?: string;
  period: string;
  location: string;
  current?: boolean;
  description: string;
  stack?: string[];
  highlights?: string[];
}

const timeline: Record<Lang, TimelineEntry[]> = {
  en: [
    {
      title: 'Development Team Lead', company: 'CloudX', companyUrl: 'https://www.cloudx.com',
      period: `Jan 2025 – ${t(lang, 'experience.present')}`, location: 'Remote · Argentina', current: true,
      description: 'Built an Agent Management Platform for a Big Four company — designed for RAG-based agents with MCP and OpenAPI plugin consumption. Led 5 cross-functional teams across India, Colombia, Paraguay, and Argentina.',
      stack: ['React', 'PostgreSQL', 'Azure Cosmos DB', 'AKS', 'Azure Functions', 'Service Bus', 'App Configuration', 'SignalR', 'Terraform', 'Microsoft Entra'],
    },
    {
      title: 'Technical Lead', company: 'CloudX', companyUrl: 'https://www.cloudx.com',
      period: 'Jan 2024 – Dec 2024', location: 'Remote',
      description: 'Led a team of 7 (2 FE, 3 BE, 1 BA, 2 QA) across Colombia and Argentina. Delivered a microservices platform to production with full documentation and client training.',
      stack: ['React', 'GraphQL', 'NSwag', 'Azure REST APIs', 'Functions', 'Service Bus', 'AKS', 'Microsoft Entra'],
    },
    {
      title: 'Technical Lead', company: 'Cognizant Softvision', companyUrl: 'https://www.cognizant.com',
      period: 'Jul 2023 – Jan 2024', location: 'Remote',
      description: 'Big Four — taxes domain. Multicultural team across India, Mexico, and Argentina. SAFe PI planning · SonarQube security hardening · code reviews.',
      stack: ['REST APIs', 'Azure Functions', 'Service Bus', 'Redis', 'SQL', 'Power BI'],
    },
    {
      title: 'Technical Lead', company: 'Cognizant Softvision', companyUrl: 'https://www.cognizant.com',
      period: 'Sep 2022 – Jul 2023', location: 'Buenos Aires',
      description: 'End-to-end delivery: from estimation and architecture to production deployment. Implemented Microsoft Bot as an AI service. Led developers, DevOps, and QA across Mexico and Argentina.',
      highlights: [
        '🏆 EOY 2022 Recognition — "Make it happen" — Top 3 .NET Community performer',
        '🎤 Speaker — Programmers Week 2022: "More Secure APIs: Addressing BOLA and BFLA"',
      ],
      stack: ['.NET', 'Azure', 'Microservices', 'Microsoft Bot', 'Microsoft Entra'],
    },
    {
      title: 'Technical Lead (Internal Project)', company: 'Cognizant Softvision', companyUrl: 'https://www.cognizant.com',
      period: 'Jun 2022 – Aug 2022', location: 'Remote',
      description: 'Internal project. Migrated .NET Core 2.2 → 6. First hands-on experience with Docker and AWS.',
      stack: ['.NET 6', 'Docker', 'AWS'],
    },
    {
      title: '.NET Developer → Tech Lead', company: 'UADE', companyUrl: 'https://www.uade.edu.ar',
      period: 'Nov 2009 – Dec 2020', location: '11 years · Buenos Aires',
      description: 'Enterprise platform serving 20,000+ users. Led development from REST API design to Azure-scale deployments and CI/CD automation.',
      stack: ['.NET 4.8', 'Oracle (PL/SQL)', 'Azure', 'Jenkins', 'REST APIs', 'Payment integrations'],
    },
    {
      title: 'Software Engineer', company: 'Tsoft', companyUrl: 'https://www.tsoftglobal.com',
      period: 'Jan 2006 – Oct 2009', location: 'Buenos Aires',
      description: 'Client: Buenos Aires Government. Large-scale document digitization project. Built data entry tools and export pipelines to document management systems.',
      stack: ['C#', 'SQL'],
    },
  ],
  es: [
    {
      title: 'Development Team Lead', company: 'CloudX', companyUrl: 'https://www.cloudx.com',
      period: `Ene 2025 – ${t(lang, 'experience.present')}`, location: 'Remoto · Argentina', current: true,
      description: 'Construí una plataforma de gestión de agentes para una empresa Big Four — diseñada para agentes RAG con consumo de herramientas MCP y plugins OpenAPI. Lideré 5 equipos cross-funcionales en India, Colombia, Paraguay y Argentina.',
      stack: ['React', 'PostgreSQL', 'Azure Cosmos DB', 'AKS', 'Azure Functions', 'Service Bus', 'App Configuration', 'SignalR', 'Terraform', 'Microsoft Entra'],
    },
    {
      title: 'Technical Lead', company: 'CloudX', companyUrl: 'https://www.cloudx.com',
      period: 'Ene 2024 – Dic 2024', location: 'Remoto',
      description: 'Lideré un equipo de 7 personas (2 FE, 3 BE, 1 BA, 2 QA) en Colombia y Argentina. Entregué una plataforma basada en microservicios a producción con documentación completa y capacitación al cliente.',
      stack: ['React', 'GraphQL', 'NSwag', 'Azure REST APIs', 'Functions', 'Service Bus', 'AKS', 'Microsoft Entra'],
    },
    {
      title: 'Technical Lead', company: 'Cognizant Softvision', companyUrl: 'https://www.cognizant.com',
      period: 'Jul 2023 – Ene 2024', location: 'Remoto',
      description: 'Big Four — dominio de impuestos. Equipo multicultural en India, México y Argentina. SAFe PI planning · hardening de seguridad con SonarQube · code reviews.',
      stack: ['REST APIs', 'Azure Functions', 'Service Bus', 'Redis', 'SQL', 'Power BI'],
    },
    {
      title: 'Technical Lead', company: 'Cognizant Softvision', companyUrl: 'https://www.cognizant.com',
      period: 'Sep 2022 – Jul 2023', location: 'Buenos Aires',
      description: 'Entrega end-to-end: desde estimaciones y arquitectura hasta deploy a producción. Implementé Microsoft Bot como servicio de IA. Lideré desarrolladores, DevOps y QA en México y Argentina.',
      highlights: [
        '🏆 Reconocimiento EOY 2022 — "Make it happen" — Top 3 de la comunidad .NET',
        '🎤 Speaker — Semana del Programador 2022: "APIs más seguras: BOLA y BFLA"',
      ],
      stack: ['.NET', 'Azure', 'Microservicios', 'Microsoft Bot', 'Microsoft Entra'],
    },
    {
      title: 'Technical Lead (Proyecto Interno)', company: 'Cognizant Softvision', companyUrl: 'https://www.cognizant.com',
      period: 'Jun 2022 – Ago 2022', location: 'Remoto',
      description: 'Proyecto interno. Migración de .NET Core 2.2 → 6. Primer contacto con Docker y AWS.',
      stack: ['.NET 6', 'Docker', 'AWS'],
    },
    {
      title: 'Desarrollador .NET → Tech Lead', company: 'UADE', companyUrl: 'https://www.uade.edu.ar',
      period: 'Nov 2009 – Dic 2020', location: '11 años · Buenos Aires',
      description: 'Plataforma enterprise con más de 20.000 usuarios. Evolución desde APIs REST hasta sistemas Azure-hosted escalables con CI/CD automatizado e integración de pagos.',
      stack: ['.NET 4.8', 'Oracle (PL/SQL)', 'Azure', 'Jenkins', 'REST APIs', 'Integración de pagos'],
    },
    {
      title: 'Software Engineer', company: 'Tsoft', companyUrl: 'https://www.tsoftglobal.com',
      period: 'Ene 2006 – Oct 2009', location: 'Buenos Aires',
      description: 'Cliente: Gobierno de la Ciudad de Buenos Aires. Proyecto de digitalización masiva de documentos. Construcción de herramientas de carga y pipelines de exportación.',
      stack: ['C#', 'SQL'],
    },
  ],
};

const statsData = {
  en: [
    { value: '20+', label: 'Years of experience' },
    { value: '5+',  label: 'Companies' },
    { value: '10+', label: 'Countries (teams)' },
    { value: '3',   label: 'Big Four projects' },
  ],
  es: [
    { value: '20+', label: 'Años de experiencia' },
    { value: '5+',  label: 'Empresas' },
    { value: '10+', label: 'Países (equipos)' },
    { value: '3',   label: 'Proyectos Big Four' },
  ],
};

const pageTitle = { en: 'Experience', es: 'Experiencia' };
const entries   = timeline[lang];
---

<BaseLayout
  lang={lang}
  title={`${pageTitle[lang]} — Adrian Majail`}
  description="20+ years of software development experience across enterprise, cloud, and AI systems."
  currentPage="experience"
>
  <div class="mx-auto max-w-4xl px-4 py-16 md:px-6 md:py-20">

    <header class="mb-10">
      <p class="eyebrow mb-1">{lang === 'en' ? 'Career' : 'Carrera'}</p>
      <span class="accent-line"></span>
      <h1 class="text-3xl font-extrabold tracking-tight text-text-primary sm:text-4xl">{pageTitle[lang]}</h1>
    </header>

    <!-- Stats -->
    <div class="mb-14 grid grid-cols-2 gap-3 rounded-xl border border-border bg-surface shadow-card p-6 sm:grid-cols-4">
      {statsData[lang].map(({ value, label }) => (
        <div class="text-center">
          <p class="text-2xl font-extrabold text-text-primary tracking-tight">{value}</p>
          <p class="mt-1 text-xs font-medium text-muted">{label}</p>
        </div>
      ))}
    </div>

    <!-- Timeline -->
    <ol class="relative border-l-2 border-border pl-6 space-y-0">
      {entries.map((entry, idx) => (
        <li class={`relative ${idx === entries.length - 1 ? 'pb-0' : 'pb-8'}`}>
          <span class={`absolute -left-[9px] top-5 h-4 w-4 rounded-full border-2 ${
            entry.current
              ? 'border-accent bg-accent shadow-sm shadow-accent/30'
              : 'border-border-2 bg-surface'
          }`}></span>

          <div class="rounded-xl border border-border bg-surface shadow-card p-5 md:p-6 hover:shadow-card-hover hover:border-border-2 transition-all">
            <div class="mb-3 flex flex-wrap items-start justify-between gap-2">
              <div>
                <h2 class="text-sm font-bold text-text-primary">
                  {entry.title}
                  <span class="font-normal text-muted"> · {entry.companyUrl
                    ? <a href={entry.companyUrl} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">{entry.company}</a>
                    : entry.company
                  }</span>
                </h2>
                <p class="mt-0.5 font-mono text-xs text-muted">{entry.period} · {entry.location}</p>
              </div>
              {entry.current && (
                <span class="inline-flex items-center gap-1.5 rounded-full border border-accent/30 bg-blue-50 px-2.5 py-1 text-xs font-semibold text-accent">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
                  {lang === 'en' ? 'Current' : 'Actual'}
                </span>
              )}
            </div>

            <p class="mb-4 text-sm text-muted leading-relaxed">{entry.description}</p>

            {entry.highlights && entry.highlights.length > 0 && (
              <ul class="mb-4 space-y-1.5">
                {entry.highlights.map((h) => (
                  <li class="text-sm text-muted">{h}</li>
                ))}
              </ul>
            )}

            {entry.stack && entry.stack.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {entry.stack.map((tag) => (
                  <span class="rounded-md border border-border px-2 py-0.5 font-mono text-xs text-muted">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </li>
      ))}
    </ol>

  </div>
</BaseLayout>
