---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const lang = Astro.params.lang as Lang;

const content = {
  en: {
    pageTitle: 'Get in touch',
    intro: "I'm always open to interesting conversations — whether it's a project, a technical challenge, or just connecting with people in the industry.",
    statusNote: 'Currently employed full-time at CloudX.',
  },
  es: {
    pageTitle: 'Contacto',
    intro: 'Siempre estoy abierto a conversaciones interesantes — ya sea un proyecto, un desafío técnico, o simplemente conectar con gente de la industria.',
    statusNote: 'Actualmente empleado full-time en CloudX.',
  },
};

const p = content[lang];

const links = [
  {
    label: 'Email',
    value: 'adrian.majail@live.com.ar',
    href: 'mailto:adrian.majail@live.com.ar',
    description: { en: 'Best for project inquiries', es: 'Ideal para consultas de proyectos' },
    iconPath: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
    stroke: true,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/amajail',
    href: 'https://linkedin.com/in/amajail',
    description: { en: 'Connect professionally', es: 'Conectar profesionalmente' },
    iconPath: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
    stroke: false,
  },
  {
    label: 'GitHub',
    value: 'github.com/amajail',
    href: 'https://github.com/amajail',
    description: { en: 'Check out my code', es: 'Ver mi código' },
    iconPath: `<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>`,
    stroke: false,
  },
];
---

<BaseLayout
  lang={lang}
  title={`${p.pageTitle} — Adrian Majail`}
  description="Get in touch with Adrian Majail — open to consulting, speaking, and collaboration."
  currentPage="contact"
>
  <div class="mx-auto max-w-2xl px-4 py-16 md:px-6 md:py-20">

    <header class="mb-10 text-center">
      <p class="eyebrow mb-1">{lang === 'en' ? 'Contact' : 'Contacto'}</p>
      <span class="accent-line mx-auto"></span>
      <h1 class="mb-4 text-3xl font-extrabold tracking-tight text-text-primary sm:text-4xl">{p.pageTitle}</h1>
      <p class="text-muted leading-relaxed">{p.intro}</p>
    </header>

    <!-- Availability -->
    <div class="mb-8 flex justify-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-blue-50 px-4 py-2 text-sm font-semibold text-accent">
        <span class="h-2 w-2 rounded-full bg-accent-cyan"></span>
        {t(lang, 'contact.availability')}
      </div>
    </div>

    <!-- Contact cards -->
    <div class="space-y-3 mb-8">
      {links.map(({ label, value, href, description, iconPath, stroke }) => (
        <a
          href={href}
          target={href.startsWith('mailto') ? undefined : '_blank'}
          rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          class="group flex items-center gap-4 rounded-xl border border-border bg-surface shadow-card p-5 transition-all hover:shadow-card-hover hover:border-accent/40"
        >
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-border bg-surface-2 text-muted group-hover:border-accent/40 group-hover:text-accent transition-colors">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill={stroke ? 'none' : 'currentColor'}
              stroke={stroke ? 'currentColor' : undefined}
              stroke-width={stroke ? '2' : undefined}
              stroke-linecap={stroke ? 'round' : undefined}
              stroke-linejoin={stroke ? 'round' : undefined}
              set:html={iconPath}
            />
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold text-muted mb-0.5">{label}</p>
            <p class="text-sm font-semibold text-text-primary truncate">{value}</p>
            <p class="text-xs text-muted mt-0.5">{description[lang]}</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-border-2 group-hover:text-accent transition-colors shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14m-7-7 7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>

    <p class="text-center text-xs text-muted">{p.statusNote}</p>

  </div>
</BaseLayout>
