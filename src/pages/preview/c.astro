---
// Prototype C — "Dark Premium": near-black, indigo accent, Stripe/Linear editorial feel
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Prototype C — Dark Premium</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #08080a;
      --surface:  #111113;
      --surface2: #18181c;
      --surface3: #1f1f25;
      --accent:   #6366f1;
      --accent-h: #4f46e5;
      --accent2:  #a5b4fc;
      --glow:     rgba(99,102,241,.15);
      --text:     #fafafa;
      --muted:    #a1a1aa;
      --border:   #27272a;
      --border2:  #3f3f46;
    }
    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
    body { font-family: 'Inter', system-ui, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    a { color: inherit; text-decoration: none; }

    /* Switcher banner */
    .switcher { background: #050505; border-bottom: 1px solid #1a1a1a; padding: 8px 24px; display: flex; align-items: center; gap: 16px; font-size: 11px; font-family: monospace; }
    .switcher span { color: #555; }
    .switcher a { color: #666; padding: 3px 10px; border: 1px solid #2a2a2a; border-radius: 4px; transition: all .2s; }
    .switcher a:hover { border-color: #444; color: #999; }
    .switcher a.current { color: #a5b4fc; border-color: #6366f1; }

    /* Nav */
    nav { position: sticky; top: 0; z-index: 50; background: rgba(8,8,10,.85); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); }
    .nav-inner { max-width: 1100px; margin: 0 auto; padding: 0 24px; height: 60px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-size: 15px; font-weight: 700; letter-spacing: -0.3px; }
    .nav-logo span { color: var(--accent2); }
    .nav-links { display: flex; align-items: center; gap: 28px; }
    .nav-links a { font-size: 13px; font-weight: 450; color: var(--muted); transition: color .2s; }
    .nav-links a:hover { color: var(--text); }
    .nav-cta { background: var(--surface2); border: 1px solid var(--border2); color: var(--text); padding: 7px 18px; border-radius: 6px; font-size: 13px; font-weight: 500; transition: all .2s; }
    .nav-cta:hover { border-color: var(--accent); color: var(--accent2); }

    /* Hero */
    .hero { position: relative; overflow: hidden; }
    .hero-glow { position: absolute; width: 600px; height: 600px; background: radial-gradient(circle, rgba(99,102,241,.12) 0%, transparent 70%); top: -100px; right: -100px; pointer-events: none; }
    .hero-glow2 { position: absolute; width: 400px; height: 400px; background: radial-gradient(circle, rgba(99,102,241,.06) 0%, transparent 70%); bottom: -50px; left: 100px; pointer-events: none; }
    .hero-inner { max-width: 1100px; margin: 0 auto; padding: 90px 24px 70px; display: grid; grid-template-columns: 1fr 400px; gap: 60px; align-items: center; position: relative; }
    .hero-badge { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(99,102,241,.4); background: rgba(99,102,241,.08); color: var(--accent2); font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 20px; margin-bottom: 28px; }
    .hero-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 8px var(--accent); display: block; }
    .hero-h1 { font-size: 50px; font-weight: 800; line-height: 1.08; letter-spacing: -2px; margin-bottom: 20px; }
    .hero-h1 em { font-style: normal; background: linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero-sub { font-size: 16px; font-weight: 450; color: var(--muted); line-height: 1.6; margin-bottom: 36px; max-width: 500px; }
    .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
    .btn-primary { background: var(--accent); color: #fff; padding: 11px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; box-shadow: 0 0 24px rgba(99,102,241,.4); transition: all .2s; }
    .btn-primary:hover { background: var(--accent-h); box-shadow: 0 0 36px rgba(99,102,241,.55); }
    .btn-secondary { border: 1px solid var(--border2); color: var(--muted); padding: 11px 24px; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all .2s; }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent2); }
    .hero-socials { display: flex; gap: 20px; }
    .hero-socials a { color: var(--muted); font-size: 12px; transition: color .2s; }
    .hero-socials a:hover { color: var(--accent2); }

    /* Right: highlight card */
    .highlight-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .card-top { background: linear-gradient(135deg, var(--surface2) 0%, rgba(99,102,241,.1) 100%); padding: 24px; border-bottom: 1px solid var(--border); }
    .card-top-label { font-size: 10px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--accent2); margin-bottom: 8px; }
    .card-top-title { font-size: 15px; font-weight: 700; color: var(--text); }
    .card-top-sub { font-size: 12px; color: var(--muted); margin-top: 4px; }
    .card-stats { padding: 20px 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); }
    .card-stat { background: var(--surface); padding: 16px; text-align: center; }
    .card-stat-val { font-size: 22px; font-weight: 800; color: var(--accent2); letter-spacing: -1px; }
    .card-stat-label { font-size: 10px; color: var(--muted); margin-top: 3px; text-transform: uppercase; letter-spacing: 0.5px; }
    .card-tags { padding: 16px 24px; display: flex; flex-wrap: wrap; gap: 6px; border-top: 1px solid var(--border); }
    .tag { font-size: 11px; color: var(--muted); border: 1px solid var(--border2); padding: 3px 9px; border-radius: 4px; }
    .tag-accent { border-color: rgba(99,102,241,.4); color: var(--accent2); background: rgba(99,102,241,.07); }

    /* Stats strip */
    .stats-strip { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .stats-inner { max-width: 1100px; margin: 0 auto; padding: 36px 24px; display: grid; grid-template-columns: repeat(4,1fr); text-align: center; gap: 24px; }
    .strip-value { font-size: 32px; font-weight: 800; letter-spacing: -1.5px; background: linear-gradient(135deg, var(--text), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .strip-label { font-size: 11px; color: var(--muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; }

    /* Section */
    .section { max-width: 1100px; margin: 0 auto; padding: 70px 24px; }
    .section-header { margin-bottom: 36px; }
    .section-label { font-size: 10px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--accent2); margin-bottom: 10px; }
    .section-title { font-size: 28px; font-weight: 700; color: var(--text); letter-spacing: -0.5px; }
    .cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 24px; transition: all .2s; position: relative; overflow: hidden; }
    .card:hover { border-color: var(--border2); transform: translateY(-2px); }
    .card-featured { border-color: rgba(99,102,241,.3); }
    .card-featured::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, var(--accent), var(--accent2)); }
    .card-eyebrow { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); margin-bottom: 10px; }
    .feat-badge { display: inline-block; font-size: 10px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--accent2); background: rgba(99,102,241,.12); border: 1px solid rgba(99,102,241,.3); padding: 2px 8px; border-radius: 3px; margin-bottom: 8px; }
    .card-title { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
    .card-body { font-size: 12px; color: var(--muted); line-height: 1.65; }

    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .highlight-card { display: none; }
      .hero-h1 { font-size: 36px; }
      .stats-inner { grid-template-columns: repeat(2,1fr); }
      .cards { grid-template-columns: 1fr; }
      .nav-links { display: none; }
    }
  </style>
</head>
<body>

  <!-- Prototype switcher -->
  <div class="switcher">
    <span>Prototype:</span>
    <a href="/preview/a">A — Navy Executive</a>
    <a href="/preview/b">B — Light Leadership</a>
    <a href="/preview/c" class="current">C — Dark Premium</a>
  </div>

  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <div class="nav-logo">Adrian <span>Majail</span></div>
      <div class="nav-links">
        <a href="#">About</a>
        <a href="#">Experience</a>
        <a href="#">Projects</a>
        <a href="#">Certifications</a>
        <a href="#" class="nav-cta">Get in touch</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-glow2"></div>
    <div class="hero-inner">
      <div>
        <div class="hero-badge">Dev Team Lead @ CloudX · Córdoba, AR</div>
        <h1 class="hero-h1">I build teams and <em>AI systems</em> that ship.</h1>
        <p class="hero-sub">.NET Tech Lead & AI Builder with 20 years turning complex problems into working software. RAG pipelines, MCP integrations, distributed systems for enterprise.</p>
        <div class="hero-actions">
          <a href="#" class="btn-primary">See my work →</a>
          <a href="#" class="btn-secondary">Get in touch</a>
        </div>
        <div class="hero-socials">
          <a href="#">GitHub</a>
          <a href="#">LinkedIn</a>
          <a href="#">Email</a>
        </div>
      </div>

      <div class="highlight-card">
        <div class="card-top">
          <div class="card-top-label">Currently building</div>
          <div class="card-top-title">Agent Management Platform</div>
          <div class="card-top-sub">Big Four · RAG + MCP + OpenAPI · 5 teams · 4 countries</div>
        </div>
        <div class="card-stats">
          <div class="card-stat"><div class="card-stat-val">20+</div><div class="card-stat-label">Yrs exp.</div></div>
          <div class="card-stat"><div class="card-stat-val">3</div><div class="card-stat-label">Big Four</div></div>
          <div class="card-stat"><div class="card-stat-val">10+</div><div class="card-stat-label">Countries</div></div>
          <div class="card-stat"><div class="card-stat-val">4</div><div class="card-stat-label">Az. certs</div></div>
        </div>
        <div class="card-tags">
          <span class="tag tag-accent">.NET / C#</span>
          <span class="tag tag-accent">Azure</span>
          <span class="tag tag-accent">AI Agents</span>
          <span class="tag">RAG</span>
          <span class="tag">MCP</span>
          <span class="tag">Terraform</span>
          <span class="tag">AZ-305</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <div class="stats-strip">
    <div class="stats-inner">
      <div><div class="strip-value">20+</div><div class="strip-label">Years of experience</div></div>
      <div><div class="strip-value">5+</div><div class="strip-label">Companies</div></div>
      <div><div class="strip-value">10+</div><div class="strip-label">Countries</div></div>
      <div><div class="strip-value">3</div><div class="strip-label">Big Four</div></div>
    </div>
  </div>

  <!-- Sample projects -->
  <section class="section">
    <div class="section-header">
      <p class="section-label">Selected Work</p>
      <h2 class="section-title">Featured Projects</h2>
    </div>
    <div class="cards">
      <div class="card card-featured">
        <div class="feat-badge">Featured</div>
        <div class="card-eyebrow">AI · CloudX · 2024–2025</div>
        <div class="card-title">Agent Management Platform</div>
        <div class="card-body">Enterprise RAG platform for a Big Four client. MCP tools, OpenAPI plugins, real-time SignalR, 5 teams across 4 countries.</div>
      </div>
      <div class="card">
        <div class="card-eyebrow">Enterprise · 2022–2024</div>
        <div class="card-title">Enterprise Tax Platform</div>
        <div class="card-body">Large-scale tax management. Microservices, Azure, Power BI reporting, SonarQube security hardening.</div>
      </div>
      <div class="card">
        <div class="card-eyebrow">Long-term · 2009–2020</div>
        <div class="card-title">University Enterprise Platform</div>
        <div class="card-body">20,000+ users. .NET monolith to Azure-hosted system with CI/CD and payment integration.</div>
      </div>
    </div>
  </section>

</body>
</html>
